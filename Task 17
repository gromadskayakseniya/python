a = int(input("Номер вертикали 1 поля: "))
b = int(input("Номер горизонтали 1 поля: "))
c = int(input("Номер вертикали 2 поля: "))
d = int(input("Номер горизонтали 2 поля: ")) 
if 0 < a and b and c and d <= 8:
    # ладья ходит по вертикали или горизонтали
    rook = (a == c) or (b == d)
    print("Ладья угрожает:", rook)

    # Слон ходит по диагонали: |x1-x2| == |y1-y2|
    bishop = (abs(a - c) == abs(b - d))
    print("Слон угрожает:", bishop)

    # Король ходит на 1 клетку в любом направлении
    king = (abs(a - c) <= 1 and abs(b - d) <= 1)
    print("Король может попасть за один ход:", king)

    # Ферзь (ладья ИЛИ слон)
    queen = (a == c) or (b == d) or (abs(a - c) == abs(b - d))
    print("Ферзь угрожает:", queen)

    # Белая пешка
    # Обычный ход: вперед на 1 по вертикали (b + 1 = d) и та же вертикаль (a == c)
    # Ход со взятием: вперед на 1 по вертикали И на 1 по горизонтали
    normal = (a == c) and (d == b + 1)
    capture = (abs(a - c) == 1) and (d == b + 1)
    print("Пешка может пойти обычным ходом:", normal)
    print("Пешка может пойти со взятием:", capture)
else:
    print("Неверные данные")
